{
  "rules": {
    ".read": false,
    ".write": false,
    "equipos": {
      ".read": true,
      ".write": true
    },
    "usuarios": {
      ".read": true,
      "$usuarioId": {
        ".write": true
      }
    },
    "predicciones": {
      ".read": true,
      "$usuarioId": {
        ".indexOn": ["timestamp"],
        ".write": true
      }
    },
    "chat_general": {
      ".read": true,
      ".write": true,
      ".indexOn": ["timestamp"]
    },
    "chat_baneados": {
      ".read": true,
      ".write": true
    },
    "clasificaciones_grupo": {
      ".read": true,
      ".write": true
    },
    "clasificaciones_grupo_test": {
      ".read": true,
      ".write": true
    },
    "rankings": {
      ".read": true,
      ".write": true
    },
    "partidos": {
      ".read": true,
      ".write": true,
      ".indexOn": ["jornada", "estado", "fecha"]
    },
    "codigos_invitacion": {
      ".read": true,
      ".write": true
    },
    "$other": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
